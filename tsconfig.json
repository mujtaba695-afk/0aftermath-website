{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "allowJs": true,
        "outDir": "./dist"
    },
    "include": [
        "src/**/*",
        "scripts/**/*",
        "*.js"
    ],
    "exclude": [
        "node_modules"
    ]
}